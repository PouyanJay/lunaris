# Lunaris environment — copy to .env (gitignored) and fill in.
#   cp .env.sample .env     (or run `make setup`, which does this for you)
#
# `make run` serves the REAL deep-agent harness by default when ANTHROPIC_API_KEY
# is set below; with the placeholder (or no key) it falls back to the deterministic
# stub pipeline, which needs NONE of these. A real key + Supabase + Voyage unlock the
# full live path: real Claude generation + pgvector grounding.

# ── Model provider (Anthropic Claude) ────────────────────────────────────────
# Set a real key to run the agent harness (the `make run` default) and `make test-eval`.
# Left at this placeholder, `make run` detects "no key" and serves the stub instead.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The two model tiers are also settable in-app: Settings → Configuration (applied to the next build).
LUNARIS_MODEL_STRONG=claude-opus-4-8
LUNARIS_MODEL_WORKER=claude-haiku-4-5-20251001

# ── Observability (LangSmith) — optional ──────────────────────────────────────
# Leave LANGSMITH_TRACING=false until you add a key (avoids 401 noise).
# Also settable in-app: Settings → Keys (LANGSMITH_API_KEY) + Settings → Configuration
# (tracing on/off + project). These are read at startup, so a change needs a restart to apply.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=lunaris

# ── Data layer (local Supabase) ───────────────────────────────────────────────
# After `make start` (or `supabase start`), run `supabase status` and paste the
# printed anon + service_role keys here. The URL/DB are the CLI defaults.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Multi-tenancy: auth + BYOK (Phase 2) — optional ───────────────────────────
# Leave both blank for single-user local dev: auth is OFF (routes open + unscoped)
# and BYOK is OFF (the app reads provider keys from this file / Settings as today).
# SUPABASE_JWT_SECRET verifies end-user login tokens locally (HS256 — `supabase
# status` prints it as "JWT secret"); cloud Supabase signs ES256/JWKS and needs no
# secret here (the verifier fetches keys from SUPABASE_URL). With it set, the user
# routes require a logged-in caller and each user sees only their own data.
SUPABASE_JWT_SECRET=
# LUNARIS_KEY_ENC_MASTER turns on per-user BYOK: tenants store their OWN encrypted
# provider keys (anthropic/voyage/search/youtube). It is the base64 AES-256 master
# key used to encrypt those keys at rest — inject it from your secret manager (Key
# Vault) in prod, NEVER commit a real one. Generate: `openssl rand -base64 32`.
# Needs Supabase configured too (that's where the encrypted keys live).
LUNARIS_KEY_ENC_MASTER=

# ── Embeddings (Voyage AI) — optional ─────────────────────────────────────────
# Enables real pgvector grounding: every corpus ingest AND every claim retrieval
# embeds via Voyage. Without it (or Supabase) the verifier degrades safely —
# claims are cut → "Needs review". NOTE: Voyage's free tier is 3 RPM — too low
# for a full course; a paid plan is needed for live grounding over a whole run.
# The corpus fills three ways (manual upload / auto-discovery / seed-from-research);
# trust model + per-mode costs: documentation/grounding-model.md.
EMBEDDINGS_API_KEY=

# ── Relevance: research + resources (Tavily / YouTube) — optional ─────────────
# SEARCH_API_KEY (Tavily) grounds the target standard in its real competencies
# AND curates vetted per-lesson external resources — both metered, bounded by a
# hard per-build budget. Absent: research → `unavailable` and no resources are
# attached; the course still builds at the RIGHT LEVEL (the relevance fix is
# prompt-driven and needs only ANTHROPIC_API_KEY). YOUTUBE_API_KEY is a further
# enhancement for richer video metadata; absent, videos come via the shared search.
# Both are also settable in-app: Settings → Keys (applied to the next build, no restart).
# See documentation/relevance-model.md.
SEARCH_API_KEY=
YOUTUBE_API_KEY=

# ── Runtime ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LUNARIS_ENV=development
